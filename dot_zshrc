#eval "$(uvx --generate-shell-completion zsh)"

source $HOME/.config/colins-zsh-cache/uv-completion.zsh
source $HOME/.config/colins-zsh-cache/uvx-completion.zsh

# Completing process IDs with menu selection:
zstyle ':completion:*:*:kill:*' menu yes select
zstyle ':completion:*:kill:*' force-list always

#interactive git diff - this is the shit!
function fshow() {
  git log --graph --color=always \
      --format="%C(auto)%h%d %s %C(black)%C(bold)%cr" "$@" \
  | fzf --ansi --preview "echo {} \
    | grep -o '[a-f0-9]\{7\}' \
    | head -1 \
    | xargs -I % sh -c 'git show --color=always %'" \
        --bind "enter:execute:
            (grep -o '[a-f0-9]\{7\}' \
                | head -1 \
                | xargs -I % sh -c 'git show --color=always % \
                | less -R') << 'FZF-EOF'
            {}
FZF-EOF"
}

source ~/playground/repos/fzf-git.sh/fzf-git.sh

if [ -f $HOME/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh ]; then
    source $HOME/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh
else
    source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh
fi

if [ -f $HOME/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]; then
    source $HOME/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
else
    source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi

# GOLANG setup
if [ -f $HOME/go/bin ]; then
   export GOPATH=$HOME/go/bin:$HOME/go/bin/bin
   export GOROOT=/usr/local/go
   export PATH=$PATH:/usr/local/go/bin:$GOPATH
fi

# needed to stop gpg signing failed: Inappropriate ioctl for device
export GPG_TTY=$(tty)

export NVM_DIR="$HOME/.nvm"
nvm() {
    unset -f nvm
    [ -s $NVM_DIR/nvm.sh ] && \. $NVM_DIR/nvm.sh --no-use
    [ -s $NVM_DIR/bash_completion ] && \.  $NVM_DIR/bash_completion
    nvm "$@"
}

