#zmodload zsh/zprof

# Set up fzf key bindings and fuzzy completion
 source <(fzf --zsh)

# Open in tmux popup if on tmux, otherwise use --height mode
export FZF_DEFAULT_OPTS='--height 40% --tmux bottom,40% --layout reverse --border top'


setopt HIST_IGNORE_SPACE # Do not record an event starting with a space.
setopt APPEND_HISTORY      # append instead of overwrite
setopt INC_APPEND_HISTORY  # write each command as it runs
setopt SHARE_HISTORY       # share history across running sessions
HISTSIZE=50000
SAVEHIST=50000
HISTFILE=~/.zsh_history

source $HOME/.vterm-setup.zsh 

if [ -x /Applications/Emacs.app/Contents/MacOS/bin/emacsclient ]; then
    emacsclient_bin=/Applications/Emacs.app/Contents/MacOS/bin/emacsclient
else
    emacsclient_bin=emacsclient
fi

if [ -n "$TMUX" ]; then
    export EDITOR="$emacsclient_bin -s server-$(tmux display-message -p '#S')"
else
    export EDITOR="$emacsclient_bin"
fi

unset emacsclient_bin

unset emacsclient_bin

# hunspell dictionary
export DICPATH=$HOME/Library/Spelling/dict-en
export DICTIONARY="en_GB,en_US"

# ls (and other's?) will display output in colour
export CLICOLOR=1

# Select the theme you want with prompt $THEME.
if [ -f $HOME/.zsh/pure/prompt_pure_setup ]; then
    fpath+=$HOME/.zsh/pure
fi

if [ -d /opt/homebrew/share/zsh/site-functions ]; then
    fpath+=("$(brew --prefix)/share/zsh/site-functions")
fi

autoload -Uz promptinit; promptinit

prompt pure

# the magic that makes site functions work. See
#
#  /opt/homebrew/share/zsh/site-functions
#
#for a list of site functions installed by homebrew.
autoload -Uz compinit
if [ $(date +'%j') != $(date -r ~/.zcompdump +'%j' 2>/dev/null) ]; then
    compinit
else
    compinit -C
fi

if [ -d /opt/homebrew/opt/fzf-tab/share/fzf-tab ]; then
    source "/opt/homebrew/opt/fzf-tab/share/fzf-tab/fzf-tab.zsh"
    # disable sort when completing `git checkout`
    zstyle ':completion:*:git-checkout:*' sort false
    # set descriptions format to enable group support
    # NOTE: don't use escape sequences (like '%F{red}%d%f') here, fzf-tab will ignore them
    zstyle ':completion:*:descriptions' format '[%d]'
    # set list-colors to enable filename colorizing
    zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
    # force zsh not to show completion menu, which allows fzf-tab to capture the unambiguous prefix
    zstyle ':completion:*' menu no
    # preview directory's content with eza when completing cd
    zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
    # custom fzf flags
    # NOTE: fzf-tab does not follow FZF_DEFAULT_OPTS by default
    zstyle ':fzf-tab:*' fzf-flags --color=fg:1,fg+:2 --bind=tab:accept
    # To make fzf-tab follow FZF_DEFAULT_OPTS.
    # NOTE: This may lead to unexpected behavior since some flags break this plugin. See Aloxaf/fzf-tab#455.
    zstyle ':fzf-tab:*' use-fzf-default-opts yes
    # switch group using `<` and `>`
    zstyle ':fzf-tab:*' switch-group '<' '>'
#    zstyle ':fzf-tab:*' fzf-command ftb-tmux-popup
    zstyle ':fzf-tab:complete:brew-(install|uninstall|search|info):*-argument-rest' fzf-preview 'HOMEBREW_COLOR=1 brew info $word'
fi

