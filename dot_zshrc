# Keep this at the top. Un-comment it, and the call at the end of the
# file to turn on startup profiling.
#
#zmodload zsh/zprof

# Set up fzf key bindings and fuzzy completion
 source <(fzf --zsh)

# Open in tmux popup if on tmux, otherwise use --height mode
export FZF_DEFAULT_OPTS='--height 40% --tmux bottom,40% --layout reverse --border top'


setopt HIST_IGNORE_SPACE # Do not record an event starting with a space.
setopt APPEND_HISTORY      # append instead of overwrite
setopt INC_APPEND_HISTORY  # write each command as it runs
setopt SHARE_HISTORY       # share history across running sessions
HISTSIZE=50000
SAVEHIST=50000
HISTFILE=~/.zsh_history

source $HOME/.vterm-setup.zsh 

if [ -f /Applications/Emacs.app//Contents/MacOS/bin/emacsclient ]; then
    export EDITOR=/Applications/Emacs.app//Contents/MacOS/bin/emacsclient
else
    export EDITOR=emacsclient
fi

# hunspell dictionary
export DICPATH=$HOME/Library/Spelling/dict-en
export DICTIONARY="en_GB,en_US"

# ls (and other's?) will display output in colour
export CLICOLOR=1

# Select the theme you want with prompt $THEME.
if [ -f $HOME/.zsh/pure/prompt_pure_setup ]; then
    fpath+=$HOME/.zsh/pure
fi

if [ -d /opt/homebrew/share/zsh/site-functions ]; then
    fpath+=("$(brew --prefix)/share/zsh/site-functions")
fi

autoload -Uz promptinit; promptinit

prompt pure

# the magic that makes site functions work. See
#
#  /opt/homebrew/share/zsh/site-functions
#
#for a list of site functions installed by homebrew.
autoload -Uz compinit
if [ $(date +'%j') != $(stat -f '%Sm' -t '%j' ~/.zcompdump) ]; then
    compinit
else
    compinit -C
fi

#eval "$(uv --generate-shell-completion zsh)"
#eval "$(uvx --generate-shell-completion zsh)"

source $HOME/.config/colins-zsh-cache/uv-completion.zsh
source $HOME/.config/colins-zsh-cache/uvx-completion.zsh

# Completing process IDs with menu selection:
zstyle ':completion:*:*:kill:*' menu yes select
zstyle ':completion:*:kill:*' force-list always

#interactive git diff - this is the shit!
function fshow() {
  git log --graph --color=always \
      --format="%C(auto)%h%d %s %C(black)%C(bold)%cr" "$@" \
  | fzf --ansi --preview "echo {} \
    | grep -o '[a-f0-9]\{7\}' \
    | head -1 \
    | xargs -I % sh -c 'git show --color=always %'" \
        --bind "enter:execute:
            (grep -o '[a-f0-9]\{7\}' \
                | head -1 \
                | xargs -I % sh -c 'git show --color=always % \
                | less -R') << 'FZF-EOF'
            {}
FZF-EOF"
}

if [ -f $HOME/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh ]; then
    source $HOME/.zsh/zsh-autosuggestions/zsh-autosuggestions.zsh
else
    source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh
fi

if [ -f $HOME/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]; then
    source $HOME/.zsh/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
else
    source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi

# GOLANG setup
if [ -f $HOME/go/bin ]; then
   export GOPATH=$HOME/go/bin:$HOME/go/bin/bin
   export GOROOT=/usr/local/go
   export PATH=$PATH:/usr/local/go/bin:$GOPATH
fi

# needed to stop gpg signing failed: Inappropriate ioctl for device
export GPG_TTY=$(tty)

export NVM_DIR="$HOME/.nvm"
nvm() {
    unset -f nvm
    [ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh" --no-use
    [ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"
    nvm "$@"
}

